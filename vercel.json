{
  "buildCommand": "cd artifacts/ring-builder && pnpm run build",
  "outputDirectory": "artifacts/ring-builder/dist/public",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "artifacts/api-server/src/data/**"
    }
  }
}
