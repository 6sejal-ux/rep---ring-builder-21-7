# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Environment secrets — never commit real credentials
.env
.env.local
.env.*.local

# ZIP archives — generated exports, never commit
*.zip

# Attached assets — instruction files uploaded during development, not part of the codebase
attached_assets/

# Generated reports — regenerate with the audit script if needed
# (comment these out if you want to track them in git)
# media-audit.json
# hidden-products-no-images.json
# hidden-products-no-images.csv

# Replit — exclude platform-specific files that don't belong in GitHub
.cache/
.local/
.replit
replit.nix
.upm/
.config/
