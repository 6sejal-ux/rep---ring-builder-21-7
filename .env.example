# Southern Star Diamonds — Ring Builder Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control — it is in .gitignore.
#
# In Replit:  add secrets via the Secrets panel (lock icon in sidebar).
# On Vercel:  add variables under Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Diamond data source ───────────────────────────────────────────────────────
# CLIENT-SAFE? NO — server-only
# "demo"   → use built-in realistic dummy data (no credentials needed)
# "nivoda" → use live Nivoda API (requires NIVODA_* vars below)
# Default is "demo" when this variable is not set.
DIAMOND_DATA_SOURCE=demo

# ── Nivoda Diamond API ────────────────────────────────────────────────────────
# CLIENT-SAFE? NO — SERVER-ONLY SECRETS (never use VITE_ prefix for these)
# Required when DIAMOND_DATA_SOURCE=nivoda
# Obtain credentials from: https://integrations.nivoda.net
NIVODA_ENDPOINT=https://integrations.nivoda.net/graphql-loupe360
NIVODA_USERNAME=your_nivoda_username
NIVODA_PASSWORD=your_nivoda_password

# ── Shopify ───────────────────────────────────────────────────────────────────
# CLIENT-SAFE? NO — SERVER-ONLY SECRETS
# Required for live cart/checkout. Without these the app redirects to /checkout-demo.
#
# SHOPIFY_STORE_DOMAIN      — your store domain (e.g. southern-star.myshopify.com)
# SHOPIFY_STOREFRONT_TOKEN  — Storefront API access token
#                             Shopify Admin → Apps → Develop apps → Create app
#                             → API credentials → Install → Storefront API access token
# SHOPIFY_ADMIN_API_TOKEN   — Admin API token (optional, only needed for draft orders)
#                             Shopify Admin → Apps → Develop apps → Your app
#                             → Admin API access scopes: read_products, write_draft_orders
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token
SHOPIFY_ADMIN_API_TOKEN=shpat_your_admin_api_token

# ── Session secret ────────────────────────────────────────────────────────────
# CLIENT-SAFE? NO — SERVER-ONLY
# Any long random string. Generate one with: openssl rand -base64 32
SESSION_SECRET=your_session_secret_here
